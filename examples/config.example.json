{
  "version": 1,
  "general": {
    "state_dir": "/data/state",
    "log_dir": "/data/logs",
    "selection": "random",
    "candidate_strategy": "full",
    "state_ttl_hours": 168,
    "request_timeout_seconds": 120,
    "connect_timeout_seconds": 10,
    "retry_count": 2,
    "retry_delay_seconds": 3,
    "page_size": 100,
    "verify_tls": true,
    "dry_run": true,
    "log_level": "info"
  },
  "instances": [
    {
      "name": "Sonarr",
      "type": "sonarr",
      "enabled": true,
      "url": "http://10.0.0.10:8989",
      "api_key_env": "SONARR_API_KEY",
      "missing": {
        "enabled": true,
        "batch_size": 1,
        "mode": "episodes"
      },
      "upgrade": {
        "enabled": true,
        "batch_size": 1,
        "mode": "episodes"
      },
      "monitored_only": true,
      "skip_future": true,
      "hourly_search_cap": 8,
      "max_download_queue_size": -1,
      "queue_error_policy": "skip"
    },
    {
      "name": "Radarr",
      "type": "radarr",
      "enabled": true,
      "url": "http://10.0.0.11:7878",
      "api_key_env": "RADARR_API_KEY",
      "missing": {
        "enabled": true,
        "batch_size": 1
      },
      "upgrade": {
        "enabled": true,
        "batch_size": 1
      },
      "monitored_only": true,
      "skip_future": true,
      "future_release_date": "digital",
      "hourly_search_cap": 8,
      "max_download_queue_size": -1,
      "queue_error_policy": "skip"
    }
  ]
}
